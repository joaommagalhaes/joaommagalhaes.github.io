  {
    "id": "async-await",
    "title": "async/await",
    "code": [
      "console.log('1')",
      "async function run() {",
      "  console.log('2')",
      "  await null",
      "  console.log('3')",
      "}",
      "run()",
      "console.log('4')"
    ],
    "steps": [
      {
        "line": -1,
        "stack": [],
        "micro": [],
        "macro": [],
        "log": [],
