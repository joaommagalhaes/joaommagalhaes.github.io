          "(continue run() after await)"
        ],
        "macro": [],
        "log": [
          "1",
          "2",
          "4"
        ],
        "note": "Logged. Script finished — call stack empty."
      },
      {
        "line": -1,
        "stack": [],
        "micro": [
          "(continue run() after await)"
        ],
        "macro": [],
        "log": [
          "1",
          "2",
          "4"
        ],
        "note": "Event loop: drain microtasks."
      },
      {
        "line": 4,
        "stack": [
          "(run() resumes)"
        ],
        "micro": [],
        "macro": [],
        "log": [
          "1",
          "2",
          "4"
        ],
