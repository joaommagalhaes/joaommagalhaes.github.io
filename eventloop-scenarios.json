  {
    "id": "event-coalescing",
    "title": "from my work: event coalescing",
    "code": [
      "let dirty = false",
      "function onEvent(e) {",
      "  state.apply(e)",
      "  if (!dirty) { dirty = true; queueMicrotask(flush) }",
      "}",
      "function flush() { dirty = false; render() }",
      "for (const e of burst) onEvent(e)  // 5 events arrive together"
    ],
    "steps": [
      {
        "line": -1,
        "stack": [],
        "micro": [],
        "macro": [],
        "log": [],
        "note": "A burst of 5 real-time events arrives together — think a socket message batch."
      },
      {
        "line": 6,
        "stack": [
          "for (e of burst)"
        ],
        "micro": [],
        "macro": [],
        "log": [],
        "note": "Loop starts."
      },
      {
        "line": 1,
        "stack": [
          "for (e of burst)",
          "onEvent(e1)"
        ],
        "micro": [],
        "macro": [],
        "log": [
          "apply e1"
        ],
        "note": "Event 1: apply it to state."
      },
      {
        "line": 3,
        "stack": [
          "for (e of burst)",
          "onEvent(e1)"
        ],
        "micro": [
          "flush"
        ],
        "macro": [],
        "log": [
          "apply e1"
        ],
        "note": "dirty was false → schedule flush() as a microtask. This guard is the whole trick: only the FIRST event in a burst schedules a flush."
      },
      {
        "line": 1,
        "stack": [
          "for (e of burst)",
          "onEvent(e2)"
        ],
        "micro": [
          "flush"
        ],
        "macro": [],
        "log": [
          "apply e1",
          "apply e2"
        ],
        "note": "Event 2: apply it. dirty is already true, so no second flush is scheduled — it rides the pending one."
      },
      {
        "line": 1,
        "stack": [
          "for (e of burst)",
          "onEvent(e3)"
        ],
        "micro": [
          "flush"
        ],
        "macro": [],
        "log": [
          "apply e1",
          "apply e2",
          "apply e3"
        ],
        "note": "Event 3: same — applied, no new flush."
      },
      {
        "line": 1,
        "stack": [
          "for (e of burst)",
          "onEvent(e4)"
        ],
        "micro": [
          "flush"
        ],
        "macro": [],
        "log": [
          "apply e1",
          "apply e2",
          "apply e3",
          "apply e4"
        ],
        "note": "Event 4."
      },
      {
        "line": 1,
        "stack": [
          "for (e of burst)",
          "onEvent(e5)"
        ],
        "micro": [
          "flush"
        ],
        "macro": [],
        "log": [
          "apply e1",
          "apply e2",
          "apply e3",
          "apply e4",
          "apply e5"
        ],
        "note": "Event 5, last in the burst."
      },
      {
        "line": -1,
        "stack": [],
        "micro": [
          "flush"
        ],
        "macro": [],
        "log": [
          "apply e1",
          "apply e2",
          "apply e3",
          "apply e4",
          "apply e5"
        ],
        "note": "Loop finished, call stack empty — all 5 events applied, exactly one flush pending."
      },
      {
        "line": 5,
        "stack": [
          "flush()"
        ],
        "micro": [],
        "macro": [],
        "log": [
          "apply e1",
          "apply e2",
          "apply e3",
          "apply e4",
          "apply e5"
        ],
        "note": "Event loop drains the microtask queue: flush() runs once."
      },
      {
        "line": 5,
        "stack": [],
        "micro": [],
        "macro": [],
        "log": [
          "apply e1",
          "apply e2",
          "apply e3",
          "apply e4",
          "apply e5",
          "render()"
        ],
        "note": "render() called exactly once for the whole burst — the same back-pressure technique from the Intermedia case study above: coalesce before you ever reach the render loop."
      }
    ]
  }
